---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import WorkItem from '../components/WorkItem.astro';
import BetCard from '../components/BetCard.astro';
import EntryRow from '../components/EntryRow.astro';
import NowReadout from '../components/NowReadout.astro';
import { site } from '../data/site';
import { url } from '../lib/utils';

const work = (await getCollection('work', ({ data }) => data.featured))
  .sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf())
  .slice(0, 3);

const bets = (await getCollection('projects', ({ data }) => data.featured && data.tier === 'bet'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 2);

const unfinished = (await getCollection('unfinished', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const essays = (await getCollection('essays', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latestEssay = essays[0];
---

<Base>
  <section class="hero">
    <div class="container">
      <p class="meta kicker fade-up">{site.name}</p>
      <h1 class="fade-up d1">{site.identity}</h1>
      <p class="lede fade-up d2">
        At Apple, I build the retail platform behind every Apple Store worldwide, the
        kind of system that cannot go down no matter how much of the world arrives at
        once. Before that, at Samsung Research, the Night Mode pipeline I helped build
        shipped to millions of Galaxy phones, working so close to the hardware that a
        millisecond was an eternity. The same engineer at both ends of the stack.
        Lately what I'm most curious about is what comes after it, so on my own time I
        bet on agents and local AI. This site keeps the record honest.
      </p>
      <p class="meta status fade-up d3">{site.statusLine}</p>
    </div>
  </section>

  <section class="section container">
    <SectionHeading num="01" title="Shipped" moreHref={url('/work/')} moreLabel="the record" />
    <div class="rows-top">
      {work.map((entry) => <WorkItem entry={entry} compact />)}
    </div>
  </section>

  <section class="section container">
    <SectionHeading num="02" title="Bets" moreHref={url('/bets/')} moreLabel="all bets" />
    <div class="bet-grid">
      {bets.map((entry) => <BetCard entry={entry} />)}
    </div>
  </section>

  <section class="section container">
    <SectionHeading num="03" title="Unfinished" moreHref={url('/unfinished/')} moreLabel="the inner track" />
    <div class="rows">
      {
        latestEssay && (
          <EntryRow
            href={url(`/essays/${latestEssay.id}/`)}
            title={latestEssay.data.title}
            date={latestEssay.data.date}
            kind="essay"
            summary={latestEssay.data.summary}
          />
        )
      }
      {
        unfinished.map((entry) => (
          <EntryRow
            href={url(`/unfinished/${entry.id}/`)}
            title={entry.data.title}
            date={entry.data.date}
            kind={entry.data.kind}
            summary={entry.data.summary}
          />
        ))
      }
    </div>
  </section>

  <section class="section container">
    <SectionHeading num="04" title="Now" moreHref={url('/about/')} moreLabel="about me" />
    <NowReadout compact />
  </section>
</Base>

<style>
  .hero {
    position: relative;
    z-index: 0;
    padding-block: clamp(4rem, 12vh, 8rem) clamp(2rem, 5vh, 3rem);
  }
  /* Grid backdrop lives on a pseudo-element so the fade mask never
     touches the hero text — only the grid fades out. */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background-image:
      linear-gradient(var(--line-faint) 1px, transparent 1px),
      linear-gradient(90deg, var(--line-faint) 1px, transparent 1px);
    background-size: 72px 72px;
    -webkit-mask-image: linear-gradient(#000 55%, transparent);
    mask-image: linear-gradient(#000 55%, transparent);
  }
  .kicker {
    margin-bottom: 1.4rem;
    color: var(--ink-2);
  }
  .hero h1 {
    font-size: clamp(2.2rem, 5.2vw, 3.55rem);
    max-width: 22ch;
    margin-bottom: 1.2rem;
  }
  .lede {
    max-width: 58ch;
    font-size: 1.12rem;
    color: var(--ink-2);
    margin-bottom: 2.2rem;
  }
  .status {
    color: var(--ink-2);
    margin-top: 3.4rem;
  }
  .rows-top {
    border-top: 1px solid var(--line);
  }
  .bet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 24rem), 1fr));
    gap: 1.2rem;
  }
</style>
