---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import BetCard from '../components/BetCard.astro';

const all = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const liveBets = all.filter((p) => p.data.tier === 'bet' && p.data.status !== 'archived');
const workshop = all.filter((p) => p.data.tier === 'workshop' && p.data.status !== 'archived');
const archived = all.filter((p) => p.data.status === 'archived');
---

<Base
  title="Bets"
  description="Wagers on where computing is going, agents and local AI today, plus the workshop of builds that sharpened the craft."
>
  <div class="container">
    <header class="page-head">
      <p class="meta">Wagers, held openly</p>
      <h1>Bets</h1>
      <p class="lede">
        Side projects are how I place bets on where computing is going. A bet is a
        thesis held until the future proves it right or wrong; the workshop below it is
        everything built along the way.
      </p>
    </header>

    <section class="tier">
      <h2 class="meta tier-label">Live bets</h2>
      <div class="bet-grid">
        {liveBets.map((entry) => <BetCard entry={entry} />)}
      </div>
    </section>

    <section class="tier workshop">
      <h2 class="meta tier-label">The workshop</h2>
      <p class="meta tier-note">builds that sharpened the craft</p>
      <div class="bet-grid">
        {workshop.map((entry) => <BetCard entry={entry} />)}
      </div>
    </section>

    {
      archived.length > 0 && (
        <section class="tier workshop">
          <h2 class="meta tier-label">Archive</h2>
          <div class="bet-grid">
            {archived.map((entry) => (
              <BetCard entry={entry} />
            ))}
          </div>
        </section>
      )
    }
  </div>
</Base>

<style>
  .page-head {
    padding-block: clamp(3rem, 8vh, 5rem) 2.5rem;
  }
  .page-head h1 {
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    margin-bottom: 0.5rem;
  }
  .lede {
    color: var(--ink-2);
    font-size: 1.08rem;
    max-width: 58ch;
  }
  .tier {
    margin-bottom: 3.2rem;
  }
  .tier-label {
    color: var(--accent);
    margin-bottom: 1.2rem;
  }
  .tier-note {
    margin: -0.8rem 0 1.2rem;
    text-transform: none;
    letter-spacing: 0.04em;
  }
  .workshop {
    padding-top: 2.4rem;
    border-top: 1px solid var(--line);
  }
  .bet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 24rem), 1fr));
    gap: 1.2rem;
  }
</style>
