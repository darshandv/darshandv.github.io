---
import { site } from '../data/site';
import { url } from '../lib/utils';
---

<footer class="container">
  <div class="bottom">
    <span class="meta">© {new Date().getFullYear()} {site.name}</span>
    <span class="meta links">
      <a href={url('/rss.xml')}>RSS</a>
    </span>
  </div>
  <p class="meta colophon">built by hand · set in Inter &amp; JetBrains Mono · no trackers</p>
</footer>

<style>
  footer {
    margin-top: var(--section-gap);
    padding-top: 3rem;
    padding-bottom: 2.5rem;
    border-top: 1px solid var(--line);
  }
  .bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .links a {
    margin-left: 1.1em;
    color: var(--ink-2);
  }
  .links a:first-child {
    margin-left: 0;
  }
  .colophon {
    margin-top: 1.6rem;
    text-transform: none;
    letter-spacing: 0.03em;
  }
</style>
