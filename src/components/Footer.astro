---
import { site } from '../data/site';
import { url } from '../lib/utils';
---

<footer class="container">
  <div class="cta">
    <h2>Want to build something together?</h2>
    <a class="email" href={`mailto:${site.email}`}>{site.email}</a>
  </div>
  <div class="bottom">
    <span class="meta">© {new Date().getFullYear()} {site.name}</span>
    <span class="meta links">
      {site.socials.map((s) => <a href={s.url} rel="me noopener">{s.label}</a>)}
      <a href={url('/rss.xml')}>RSS</a>
    </span>
  </div>
  <p class="meta colophon">built by hand · set in Inter &amp; JetBrains Mono · no trackers</p>
</footer>

<style>
  footer {
    margin-top: var(--section-gap);
    padding-bottom: 2.5rem;
  }
  .cta {
    border-top: 1px solid var(--line);
    padding-top: 3rem;
    margin-bottom: 3rem;
  }
  .cta h2 {
    font-size: clamp(1.4rem, 3.4vw, 2rem);
    margin-bottom: 0.4rem;
  }
  .email {
    font-family: var(--font-mono);
    font-size: 0.95rem;
  }
  .bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.6rem;
    border-top: 1px solid var(--line-faint);
    padding-top: 1.2rem;
  }
  .links a {
    margin-left: 1.1em;
    color: var(--ink-2);
  }
  .links a:first-child {
    margin-left: 0;
  }
  .colophon {
    margin-top: 1.6rem;
    text-transform: none;
    letter-spacing: 0.03em;
  }
</style>
